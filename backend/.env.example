# Copy to .env and .env.local for local development.
# These real env files are gitignored; only this example is committed.
#
# Quick start:
#   cp .env.example .env
#   cp .env.example .env.local
#
# Production example:
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-frontend.example.com,https://www.your-frontend.example.com
# API_HOST=0.0.0.0
# API_PORT=8000

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000
